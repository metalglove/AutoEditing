<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        MinWidth="620" MinHeight="560"
        Background="#2B2B2E" FontFamily="Segoe UI" FontSize="13" TextOptions.TextFormattingMode="Ideal">
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding AnalyzeCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <!-- VEGAS Pro 20 dark theme palette -->
        <SolidColorBrush x:Key="AppBackground" Color="#2B2B2E" />
        <SolidColorBrush x:Key="SidebarBackground" Color="#202022" />
        <SolidColorBrush x:Key="CardBackground" Color="#323236" />
        <SolidColorBrush x:Key="CardBorder" Color="#3D3D42" />
        <SolidColorBrush x:Key="InputBackground" Color="#1B1B1D" />
        <SolidColorBrush x:Key="InputBorder" Color="#46464C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#ECECEC" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9A9AA2" />
        <SolidColorBrush x:Key="TextLabel" Color="#B4B4BC" />
        <SolidColorBrush x:Key="Accent" Color="#4F7CF6" />
        <SolidColorBrush x:Key="AccentMuted" Color="#8EA2FF" />
        <SolidColorBrush x:Key="QuietFill" Color="#3A3A40" />
        <SolidColorBrush x:Key="QuietBorder" Color="#4A4A51" />
        <SolidColorBrush x:Key="DangerFill" Color="#40232A" />
        <SolidColorBrush x:Key="DangerText" Color="#F08A96" />
        <SolidColorBrush x:Key="DangerBorder" Color="#5A2E37" />
        <SolidColorBrush x:Key="LogBackground" Color="#171719" />
        <SolidColorBrush x:Key="LogText" Color="#8FE3B0" />
        <SolidColorBrush x:Key="DotOk" Color="#34D399" />
        <SolidColorBrush x:Key="DotBad" Color="#F0556A" />
        <SolidColorBrush x:Key="StepFill" Color="#39414F" />
        <SolidColorBrush x:Key="SidebarText" Color="#ECECEC" />
        <SolidColorBrush x:Key="SidebarMuted" Color="#8A8A93" />
        <SolidColorBrush x:Key="LivePanelBackground" Color="#26262A" />
        <SolidColorBrush x:Key="LivePanelBorder" Color="#35353B" />
        <SolidColorBrush x:Key="LiveAccent" Color="#6EE7B7" />
        <SolidColorBrush x:Key="LiveText" Color="#B6B6C0" />
        <SolidColorBrush x:Key="BadgeBackground" Color="#2A3352" />
        <SolidColorBrush x:Key="BadgeText" Color="#93A4FF" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,9,0" />
            <Setter Property="Background" Value="{StaticResource QuietFill}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource QuietBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2F2F34" />
            <Setter Property="BorderBrush" Value="{StaticResource QuietBorder}" />
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerFill}" />
            <Setter Property="Foreground" Value="{StaticResource DangerText}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBorder}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLabel}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="StepNumber" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{StaticResource StepFill}" />
            <Setter Property="Margin" Value="0,0,11,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="235" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}">
            <Grid Margin="24">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,5,0,32">
                    <TextBlock Text="AUTOEDITING" Foreground="{StaticResource AccentMuted}" FontWeight="Bold" FontSize="11" />
                    <TextBlock Text="Shot Review" Foreground="{StaticResource SidebarText}" FontWeight="SemiBold" FontSize="24" Margin="0,6,0,0" />
                    <TextBlock Text="Template-aware montage sync" Foreground="{StaticResource SidebarMuted}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepNumber}"><TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        <StackPanel Grid.Column="1"><TextBlock Text="Choose sources" Foreground="{StaticResource SidebarText}" FontWeight="SemiBold" /><TextBlock Text="Clips, song, and SFX" Foreground="{StaticResource SidebarMuted}" FontSize="11" /></StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepNumber}"><TextBlock Text="2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        <StackPanel Grid.Column="1"><TextBlock Text="Analyze" Foreground="{StaticResource SidebarText}" FontWeight="SemiBold" /><TextBlock Text="Generate review markers" Foreground="{StaticResource SidebarMuted}" FontSize="11" /></StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepNumber}"><TextBlock Text="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        <StackPanel Grid.Column="1"><TextBlock Text="Review &amp; build" Foreground="{StaticResource SidebarText}" FontWeight="SemiBold" /><TextBlock Text="Correct markers, sync beats" Foreground="{StaticResource SidebarMuted}" FontSize="11" /></StackPanel>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="3" Background="{StaticResource LivePanelBackground}" BorderBrush="{StaticResource LivePanelBorder}" BorderThickness="1" CornerRadius="7" Padding="12">
                    <StackPanel>
                        <TextBlock Text="●  LIVE PANEL" Foreground="{StaticResource LiveAccent}" FontWeight="Bold" FontSize="10" />
                        <TextBlock Text="VEGAS remains interactive. Move the timeline cursor while this panel stays open."
                                   Foreground="{StaticResource LiveText}" FontSize="11" TextWrapping="Wrap" Margin="0,7,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="26,22,26,22">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="210" /></Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Prepare and review your montage" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="Ctrl+Enter analyzes clips  •  Esc cancels the active operation"
                               Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource BadgeBackground}" CornerRadius="14" Padding="12,6" VerticalAlignment="Center">
                    <TextBlock Text="WPF · ASYNC" Foreground="{StaticResource BadgeText}" FontWeight="Bold" FontSize="10" />
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,4,18">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,13">
                        <StackPanel>
                            <TextBlock Text="Sources" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Valid paths show a green status dot." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,16" />

                            <TextBlock Text="CLIPS FOLDER" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource DotBad}" /><Style.Triggers><DataTrigger Binding="{Binding ClipsFolderExists}" Value="True"><Setter Property="Fill" Value="{StaticResource DotOk}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                                </Ellipse>
                                <TextBox Grid.Column="1" Text="{Binding ClipsFolder, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" />
                                <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseClipsCommand}" Margin="10,0,0,0" />
                            </Grid>

                            <TextBlock Text="SONG" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource DotBad}" /><Style.Triggers><DataTrigger Binding="{Binding SongExists}" Value="True"><Setter Property="Fill" Value="{StaticResource DotOk}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                <TextBox Grid.Column="1" Text="{Binding SongPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" />
                                <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseSongCommand}" Margin="10,0,0,0" />
                            </Grid>

                            <TextBlock Text="SFX TEMPLATE FOLDER" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource DotBad}" /><Style.Triggers><DataTrigger Binding="{Binding SfxRootExists}" Value="True"><Setter Property="Fill" Value="{StaticResource DotOk}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                <TextBox Grid.Column="1" Text="{Binding SfxRoot, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" />
                                <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseSfxCommand}" Margin="10,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,13">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Template index &amp; analysis" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Index only when SFX files change. Analyze creates full-length review regions and markers."
                                           Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,4,20,13" TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Button Content="Index templates" Command="{Binding IndexSfxCommand}" ToolTip="Rebuild template fingerprints and clean-audio onsets" />
                                    <Button Content="Validate index" Command="{Binding ValidateSfxCommand}" Style="{StaticResource QuietButton}" />
                                </WrapPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Analyze clips" Command="{Binding AnalyzeCommand}"
                                    Style="{StaticResource PrimaryButton}" Width="130" Height="44" Margin="0" VerticalAlignment="Center"
                                    ToolTip="Analyze clips (Ctrl+Enter)" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Review markers" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Move the VEGAS cursor, then classify or add a marker. Candidate markers are ignored by the montage."
                                           Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,4,20,13" TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Button Content="Hit" Command="{Binding MarkHitCommand}" />
                                    <Button Content="Headshot" Command="{Binding MarkHeadshotCommand}" />
                                    <Button Content="Miss" Command="{Binding MarkMissCommand}" Style="{StaticResource QuietButton}" />
                                </WrapPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Build montage" Command="{Binding BuildMontageCommand}"
                                    Style="{StaticResource PrimaryButton}" Width="130" Height="44" Margin="0" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="15,11,8,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Activity" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clear log" Command="{Binding ClearLogCommand}" Style="{StaticResource QuietButton}" Height="30" Padding="10,0" />
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}"
                                Height="30" Padding="10,0" Margin="0" />
                    </Grid>
                    <ProgressBar Grid.Row="0" Height="3" Margin="0,59,0,0" VerticalAlignment="Top"
                                 Minimum="0" Maximum="{Binding ProgressMaximum}" Value="{Binding ProgressValue}"
                                 IsIndeterminate="{Binding IsIndeterminate}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Accent}" />
                    <Border Grid.Row="1" Background="{StaticResource LogBackground}" CornerRadius="0,0,8,8" Margin="0,3,0,0">
                        <TextBox x:Name="LogBox" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" Foreground="{StaticResource LogText}" BorderThickness="0" Height="Auto"
                                 FontFamily="Consolas" FontSize="11" Padding="12" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
