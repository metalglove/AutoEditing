<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" MinWidth="760" MinHeight="620"
 Background="#2B2B2E" FontFamily="Segoe UI" FontSize="13">
 <UserControl.InputBindings><KeyBinding Key="Escape" Command="{Binding CancelCommand}" /></UserControl.InputBindings>
 <UserControl.Resources>
  <!-- VEGAS Pro 20 dark theme palette -->
  <SolidColorBrush x:Key="AppBackground" Color="#2B2B2E"/><SolidColorBrush x:Key="SidebarBackground" Color="#202022"/>
  <SolidColorBrush x:Key="CardBackground" Color="#323236"/><SolidColorBrush x:Key="CardBorder" Color="#3D3D42"/>
  <SolidColorBrush x:Key="InputBackground" Color="#1B1B1D"/><SolidColorBrush x:Key="InputBorder" Color="#46464C"/>
  <SolidColorBrush x:Key="TextPrimary" Color="#ECECEC"/><SolidColorBrush x:Key="TextSecondary" Color="#9A9AA2"/>
  <SolidColorBrush x:Key="TextLabel" Color="#B4B4BC"/><SolidColorBrush x:Key="Accent" Color="#4F7CF6"/>
  <SolidColorBrush x:Key="AccentMuted" Color="#8EA2FF"/><SolidColorBrush x:Key="QuietFill" Color="#3A3A40"/>
  <SolidColorBrush x:Key="QuietBorder" Color="#4A4A51"/><SolidColorBrush x:Key="DangerFill" Color="#40232A"/>
  <SolidColorBrush x:Key="DangerText" Color="#F08A96"/><SolidColorBrush x:Key="DangerBorder" Color="#5A2E37"/>
  <SolidColorBrush x:Key="LogBackground" Color="#171719"/><SolidColorBrush x:Key="LogText" Color="#8FE3B0"/>
  <SolidColorBrush x:Key="DotOk" Color="#34D399"/><SolidColorBrush x:Key="DotBad" Color="#F0556A"/>
  <SolidColorBrush x:Key="StepFill" Color="#39414F"/><SolidColorBrush x:Key="SidebarText" Color="#ECECEC"/>
  <SolidColorBrush x:Key="SidebarMuted" Color="#8A8A93"/>
  <Style TargetType="Button">
   <Setter Property="Height" Value="36"/><Setter Property="Padding" Value="13,0"/><Setter Property="Margin" Value="0,0,9,0"/>
   <Setter Property="Background" Value="{StaticResource QuietFill}"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
   <Setter Property="BorderBrush" Value="{StaticResource QuietBorder}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Cursor" Value="Hand"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="Button">
      <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
       <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <ControlTemplate.Triggers>
       <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.86"/></Trigger>
       <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.7"/></Trigger>
       <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
      </ControlTemplate.Triggers>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
  <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="BorderBrush" Value="{StaticResource Accent}"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
  <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{StaticResource DangerFill}"/><Setter Property="Foreground" Value="{StaticResource DangerText}"/><Setter Property="BorderBrush" Value="{StaticResource DangerBorder}"/></Style>
  <Style TargetType="TextBox"><Setter Property="Height" Value="36"/><Setter Property="Padding" Value="9,6"/><Setter Property="Background" Value="{StaticResource InputBackground}"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/></Style>
  <Style TargetType="ComboBoxItem">
   <Setter Property="Padding" Value="8,4"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="ComboBoxItem">
      <Border x:Name="ItemBorder" Background="Transparent" Padding="{TemplateBinding Padding}">
       <ContentPresenter/>
      </Border>
      <ControlTemplate.Triggers>
       <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource StepFill}"/></Trigger>
       <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Accent}"/></Trigger>
      </ControlTemplate.Triggers>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
  <Style TargetType="ComboBox">
   <Setter Property="Background" Value="{StaticResource InputBackground}"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
   <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/><Setter Property="BorderThickness" Value="1"/>
   <Setter Property="Padding" Value="8,0,22,0"/><Setter Property="MinHeight" Value="28"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="ComboBox">
      <Grid>
       <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
        <ToggleButton.Template>
         <ControlTemplate TargetType="ToggleButton">
          <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}" CornerRadius="4">
           <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextSecondary}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,9,0"/>
          </Border>
         </ControlTemplate>
        </ToggleButton.Template>
       </ToggleButton>
       <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
       <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Margin="{TemplateBinding Padding}" VerticalContentAlignment="Center" IsReadOnly="{TemplateBinding IsReadOnly}" Focusable="True"/>
       <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
        <Border Background="{StaticResource InputBackground}" BorderBrush="{StaticResource InputBorder}" BorderThickness="1" CornerRadius="4" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="240">
         <ScrollViewer SnapsToDevicePixels="True"><ItemsPresenter/></ScrollViewer>
        </Border>
       </Popup>
      </Grid>
      <ControlTemplate.Triggers>
       <Trigger Property="IsEditable" Value="True">
        <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
        <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
       </Trigger>
      </ControlTemplate.Triggers>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
  <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="{StaticResource CardBackground}"/><Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="9"/><Setter Property="Padding" Value="18"/></Style>
  <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextLabel}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="12"/><Setter Property="Margin" Value="0,0,0,6"/></Style>
  <Style TargetType="DataGrid"><Setter Property="Background" Value="{StaticResource InputBackground}"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/><Setter Property="RowBackground" Value="#29292D"/><Setter Property="AlternatingRowBackground" Value="#303035"/><Setter Property="GridLinesVisibility" Value="Horizontal"/><Setter Property="HorizontalGridLinesBrush" Value="{StaticResource CardBorder}"/><Setter Property="HeadersVisibility" Value="Column"/></Style>
  <Style TargetType="DataGridColumnHeader">
   <Setter Property="Background" Value="{StaticResource QuietFill}"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
   <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="8,7"/><Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/><Setter Property="BorderThickness" Value="0,0,1,1"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="DataGridColumnHeader">
      <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
       <ContentPresenter VerticalAlignment="Center"/>
      </Border>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
  <Style TargetType="DataGridCell">
   <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="Padding" Value="6,3"/>
   <Style.Triggers>
    <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource StepFill}"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderThickness" Value="0"/></Trigger>
   </Style.Triggers>
  </Style>
 </UserControl.Resources>
 <Grid>
  <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <Border Background="{StaticResource SidebarBackground}"><Grid Margin="22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
   <StackPanel Margin="0,4,0,24"><TextBlock Text="AUTOEDITING" Foreground="{StaticResource AccentMuted}" FontWeight="Bold" FontSize="11"/><TextBlock Text="Shot Review" Foreground="{StaticResource SidebarText}" FontSize="24" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
   <ItemsControl Grid.Row="1" ItemsSource="{Binding Steps}"><ItemsControl.ItemTemplate><DataTemplate><Border Margin="0,0,0,10" Padding="8" CornerRadius="6"><Border.Style><Style TargetType="Border"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsCurrent}" Value="True"><Setter Property="Background" Value="{StaticResource StepFill}"/></DataTrigger></Style.Triggers></Style></Border.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Number}" Foreground="{StaticResource AccentMuted}" FontWeight="Bold"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" Foreground="{StaticResource SidebarText}" FontWeight="SemiBold"/><TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource SidebarMuted}" FontSize="11"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
   <Button Grid.Row="2" Content="?  How it works" Command="{Binding ShowOnboardingCommand}" Margin="0"/>
  </Grid></Border>
  <Grid Grid.Column="1" Margin="24,20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="175"/></Grid.RowDefinitions>
   <Grid Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Shot Review wizard" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><TextBlock Text="Confirm reusable sync points, then build from the clip drawer." Foreground="{StaticResource TextSecondary}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Back" Command="{Binding PreviousStepCommand}"/><Button Content="Next" Command="{Binding NextStepCommand}" Style="{StaticResource PrimaryButton}" Margin="0"/></StackPanel></Grid>
   <Grid Grid.Row="1" Margin="0,0,0,12">
    <Border><Border.Style><Style TargetType="Border" BasedOn="{StaticResource Card}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsSourcesStep}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><StackPanel><TextBlock Text="1 · Choose sources" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/><TextBlock Text="CLIPS FOLDER" Style="{StaticResource FieldLabel}"/><Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Text="{Binding ClipsFolder, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseClipsCommand}" Margin="10,0,0,0"/></Grid><TextBlock Text="SONG" Style="{StaticResource FieldLabel}"/><Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Text="{Binding SongPath, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseSongCommand}" Margin="10,0,0,0"/></Grid><TextBlock Text="SFX TEMPLATE FOLDER" Style="{StaticResource FieldLabel}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Text="{Binding SfxRoot, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseSfxCommand}" Margin="10,0,0,0"/></Grid></StackPanel></Border>
    <Border><Border.Style><Style TargetType="Border" BasedOn="{StaticResource Card}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsSongAnalysisStep}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="3*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="2 · Song map" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><TextBlock Text="{Binding SongAnalysisSummary}" Foreground="{StaticResource TextSecondary}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><ComboBox ItemsSource="{Binding SongEventViewModes}" SelectedItem="{Binding SongEventViewMode}" Width="185" Margin="0,0,10,0"/><Button Content="Re-analyze" Command="{Binding AnalyzeSongCommand}" Margin="0"/></StackPanel></Grid><Grid Grid.Row="1" Margin="0,12,0,6"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="DETECTED REGIONS" Style="{StaticResource FieldLabel}"/><DataGrid Grid.Row="1" ItemsSource="{Binding SongRegions}" SelectedItem="{Binding SelectedSongRegion}" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="Use" Binding="{Binding IsIncluded}"/><DataGridTextColumn Header="Range" Binding="{Binding Range}" IsReadOnly="True"/><DataGridTemplateColumn Header="Region type"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTextColumn Header="Energy" Binding="{Binding Energy}" IsReadOnly="True"/><DataGridTextColumn Header="Change" Binding="{Binding Change}" IsReadOnly="True"/><DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" IsReadOnly="True"/></DataGrid.Columns></DataGrid></Grid><Grid Grid.Row="2" Margin="0,6"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="SYNC POINTS" Style="{StaticResource FieldLabel}"/><DataGrid Grid.Row="1" ItemsSource="{Binding SongEvents}" SelectedItem="{Binding SelectedSongEvent}" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="Use" Binding="{Binding IsIncluded}"/><DataGridTextColumn Header="Time" Binding="{Binding Time}" IsReadOnly="True"/><DataGridTemplateColumn Header="Type"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTextColumn Header="Strength" Binding="{Binding Strength}" IsReadOnly="True"/><DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" IsReadOnly="True"/><DataGridTextColumn Header="Origin" Binding="{Binding Origin}" IsReadOnly="True"/></DataGrid.Columns></DataGrid></Grid><Grid Grid.Row="3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Layer the inspector by regions, meaningful sync points, the selected region, or every detected event." Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Jump to selected" Command="{Binding JumpSongEventCommand}"/><Button Content="Delete selected" Command="{Binding DeleteSongEventCommand}" Style="{StaticResource DangerButton}"/><Button Content="Commit song map" Command="{Binding CommitSongReviewCommand}" Style="{StaticResource PrimaryButton}" Margin="0"/></StackPanel></Grid></Grid></Border>
    <Border><Border.Style><Style TargetType="Border" BasedOn="{StaticResource Card}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsSfxStep}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><StackPanel><TextBlock Text="3 · SFX index" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><TextBlock Text="The existing index is validated automatically when this step opens. Re-index only after template files change." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,7,0,18"/><WrapPanel><Button Content="Index templates" Command="{Binding IndexSfxCommand}"/><Button Content="Validate now" Command="{Binding ValidateSfxCommand}"/></WrapPanel></StackPanel></Border>
    <Border><Border.Style><Style TargetType="Border" BasedOn="{StaticResource Card}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsAnalyzeStep}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><StackPanel><TextBlock Text="4 · Analyze clips" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><TextBlock Text="Ready library clips reuse their sync points. New or changed clips are detected and placed on temporary review tracks." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,7,0,18"/><Button Content="Analyze and continue" Command="{Binding AnalyzeCommand}" Style="{StaticResource PrimaryButton}" Width="180" HorizontalAlignment="Left"/></StackPanel></Border>
    <Border><Border.Style><Style TargetType="Border" BasedOn="{StaticResource Card}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsReviewStep}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding ReviewHeader}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Prev clip" Command="{Binding PreviousClipCommand}"/><Button Content="Next clip" Command="{Binding NextClipCommand}" Margin="0"/></StackPanel></Grid><DataGrid Grid.Row="1" Margin="0,12" ItemsSource="{Binding Markers}" SelectedItem="{Binding SelectedMarker}" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="Time" Binding="{Binding Time}" IsReadOnly="True"/><DataGridTemplateColumn Header="Outcome"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding OutcomeOptions}" SelectedItem="{Binding Outcome, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTemplateColumn Header="Gun"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding GunOptions}" SelectedItem="{Binding Gun, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" IsReadOnly="True"/><DataGridTextColumn Header="Template" Binding="{Binding TemplateId}" IsReadOnly="True" Width="*"/></DataGrid.Columns></DataGrid><Grid Grid.Row="2"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Outcome, gun, additions, and deletions are committed together when the clip is marked ready. Move the VEGAS cursor to a missed shot, then add it below." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/><WrapPanel Grid.Row="1"><Button Content="+ Hit" Command="{Binding AddHitCommand}"/><Button Content="+ Headshot" Command="{Binding AddHeadshotCommand}"/><Button Content="+ Miss" Command="{Binding AddMissCommand}"/><Button Content="Delete" Command="{Binding DeleteMarkerCommand}" Style="{StaticResource DangerButton}"/><Button Content="Jump to" Command="{Binding JumpMarkerCommand}"/><Button Content="Refresh after nudge" Command="{Binding RefreshMarkersCommand}"/></WrapPanel><Button Grid.Row="1" Grid.Column="1" Content="Mark clip ready" Command="{Binding MarkClipReadyCommand}" Style="{StaticResource PrimaryButton}" Margin="0" VerticalAlignment="Top"/></Grid></Grid></Border>
    <Border><Border.Style><Style TargetType="Border" BasedOn="{StaticResource Card}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsDrawerStep}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="6 · Clip drawer" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><TextBlock Text="Select reusable ready clips for the montage." Foreground="{StaticResource TextSecondary}"/></StackPanel><Button Grid.Column="1" Content="+ folder" Command="{Binding AddKnownFolderCommand}" Margin="0"/></Grid><DataGrid Grid.Row="1" Margin="0,12" ItemsSource="{Binding DrawerRows}" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="Use" Binding="{Binding IsSelected}"/><DataGridCheckBoxColumn Header="Exists" Binding="{Binding FileExists}" IsReadOnly="True"/><DataGridTextColumn Header="Player" Binding="{Binding Player}"/><DataGridTextColumn Header="Game / Map" Binding="{Binding Game}"/><DataGridTextColumn Header="Guns" Binding="{Binding Guns}"/><DataGridCheckBoxColumn Header="Swap" Binding="{Binding IsSwap}"/><DataGridTextColumn Header="Syncs" Binding="{Binding SyncPointCount}"/><DataGridTextColumn Header="Lead times" Binding="{Binding LeadTimes}" Width="*"/><DataGridCheckBoxColumn Header="Ready" Binding="{Binding IsReady}" IsReadOnly="True"/></DataGrid.Columns></DataGrid><Button Grid.Row="2" Content="Build montage" Command="{Binding BuildMontageCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0"/></Grid></Border>
   </Grid>
   <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid Margin="12,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/><Button Grid.Column="1" Content="Clear" Command="{Binding ClearLogCommand}" Height="28"/><Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" Height="28" Margin="0"/></Grid><ProgressBar Height="3" VerticalAlignment="Bottom" Maximum="{Binding ProgressMaximum}" Value="{Binding ProgressValue}" IsIndeterminate="{Binding IsIndeterminate}" Foreground="{StaticResource Accent}"/><TextBox x:Name="LogBox" Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{StaticResource LogBackground}" Foreground="{StaticResource LogText}" BorderThickness="0" Height="Auto" FontFamily="Consolas" FontSize="11"/></Grid></Border>
  </Grid>
  <Grid Grid.ColumnSpan="2" Panel.ZIndex="20"><Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding ShowOnboarding}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Grid.Style><Border Background="#DD171719"/><Border Width="590" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Card}" Padding="28"><StackPanel><TextBlock Text="From raw clips to reusable sync points" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/><TextBlock Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,14,0,18"><Run FontWeight="Bold" Foreground="{StaticResource TextPrimary}">1. Sources:</Run><Run Text=" choose clips, song, and SFX.&#x0a;&#x0a;"/><Run FontWeight="Bold" Foreground="{StaticResource TextPrimary}">2. SFX index:</Run><Run Text=" validate the sound templates.&#x0a;&#x0a;"/><Run FontWeight="Bold" Foreground="{StaticResource TextPrimary}">3. Analyze:</Run><Run Text=" detect candidate moments only for clips not already known.&#x0a;&#x0a;"/><Run FontWeight="Bold" Foreground="{StaticResource TextPrimary}">4. Review:</Run><Run Text=" reclassify outcome/gun, drag an existing marker in VEGAS to retime it then click Refresh, delete a wrong row, or move the VEGAS cursor to a missed shot and add it with + Hit/+ Headshot/+ Miss. The complete review is committed when you mark the clip ready, then the temporary timeline objects are removed.&#x0a;&#x0a;"/><Run FontWeight="Bold" Foreground="{StaticResource TextPrimary}">5. Drawer:</Run><Run Text=" browse ready clips and build a montage without keeping source clips laid out."/></TextBlock><Button Content="Got it" Command="{Binding DismissOnboardingCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0"/></StackPanel></Border></Grid>
 </Grid>
</UserControl>
